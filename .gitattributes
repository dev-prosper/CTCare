# Line endings
# Set default behaviour to automatically normalize line endings
* text=auto

# Explicitly declare text files with specific line endings
*.txt text eol=lf
*.md text eol=lf diff=markdown
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.html text eol=lf
*.json text eol=lf diff=json
*.sh text eol=lf

# Windows specific files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.pdf binary

# Files and directories to exclude from archives
.gitattributes export-ignore
.gitignore export-ignore
.github/ export-ignore
*.test.js export-ignore
*.test.ts export-ignore
*.spec.js export-ignore
*.spec.ts export-ignore

# Lockfiles - prevent Git from trying to merge or diff
package-lock.json binary
yarn.lock        binary
pnpm-lock.yaml   binary
bun.lockb        binary

# Config files (text, force LF)
.env.*           text eol=lf
*.config.js      text eol=lf
*.config.cjs     text eol=lf
*.config.mjs     text eol=lf
*.config.ts      text eol=lf
tailwind.config.* text eol=lf
postcss.config.* text eol=lf
next.config.*    text eol=lf
tsconfig.json    text eol=lf
.eslintrc.*      text eol=lf
.prettierrc*     text eol=lf
.editorconfig    text eol=lf